generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Channel {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  url       String
  handle    String?
  youtubeId String?
  createdAt DateTime @default(now())

  ideas Idea[]
  jobs  Job[]
}

model Idea {
  id           String   @id @default(cuid())
  channelId     String
  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  topic         String
  hook          String
  title         String
  thumbnail     String
  thumbnailUrl  String?
  source        String   @default("local")
  createdAt     DateTime @default(now())
}

model Job {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  type      String
  status    String   @default("queued")
  payload   String
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  image              String?
  emailVerified      DateTime?
  username           String?   @unique
  firstName          String?
  lastName           String?
  passwordHash       String?
  pendingEmail       String?
  emailChangeToken   String?
  emailChangeExpires DateTime?
  createdAt          DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  channels Channel[]
  jobs     Job[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}